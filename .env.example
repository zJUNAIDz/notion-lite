NEXT_PUBLIC_CONVEX_URL="convex-cloud-url"
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="clerk-auth-publishable-key"
CLERK_SECRET_KEY="secret-key"
EDGE_STORE_ACCESS_KEY=""
EDGE_STORE_SECRET_KEY=""

# Base URL of the Yjs collaboration worker (collaboration-server/). The document
# id is appended as the path, so don't include a trailing slash or id here.
# Local `wrangler dev` serves it at ws://localhost:8787 (the default when unset).
NEXT_PUBLIC_COLLAB_WS_URL="ws://localhost:8787"